# PostgreSQL Configuration
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=mnemos
PG_USER=mnemos_user
PG_PASSWORD=mnemos_secure_password

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false
API_THREADED=true
API_VERSION=2.0-merged-modular

# GRAEAE Configuration
GRAEAE_HOST=localhost
GRAEAE_PORT=5001
GRAEAE_URL=http://localhost:5001
GRAEAE_FALLBACK_ON_ERROR=true

# Ollama Configuration
OLLAMA_HOST=http://192.168.207.96:8000
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_TIMEOUT=10

# Feature Flags
ENABLE_TIER_SELECTION=true
ENABLE_GRAEAE=true
ENABLE_BACKGROUND_EMBEDDING=true
ENABLE_DISTILLATION=true
ENABLE_JSON_SHARD_SYNC=true

# Performance
MAX_MEMORIES=10000
MEMORY_TTL_DAYS=7
CACHE_TTL_MINUTES=60
