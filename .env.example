# MNEMOS Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# --- Database ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=mnemos
PG_USER=mnemos_user
PG_PASSWORD=change_me_before_use

# --- API ---
MNEMOS_PORT=5002
MNEMOS_BIND=127.0.0.1
MNEMOS_API_KEY=

# --- Authentication ---
MNEMOS_AUTH_MODE=none
# Options: none (unauthenticated), key (API key required), jwt

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# --- Embedding ---
OLLAMA_EMBED_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_TIMEOUT=10

# --- Feature Flags ---
ENABLE_GRAEAE=true
ENABLE_BACKGROUND_EMBEDDING=true
ENABLE_DISTILLATION=true

# --- GRAEAE (optional: provider API keys) ---
# Place in ~/.config/mnemos/api_keys.json (see docs/)
# Or set inline:
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...

# --- Logging ---
LOG_LEVEL=INFO
