# MNEMOS v3.0.0 Configuration
# Copy to .env and customize for your deployment

# ── Server Configuration ──────────────────────────────────────────────────────
MNEMOS_PORT=5002
MNEMOS_BIND=127.0.0.1
MNEMOS_WORKERS=1  # IMPORTANT: Keep at 1 for in-process state (rate limiters, circuit breakers)

# ── Database Configuration ────────────────────────────────────────────────────
# PostgreSQL connection for memory storage, audit logs, sessions, and DAG versioning
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=mnemos
PG_USER=mnemos
PG_PASSWORD=your_secure_password_here
PG_POOL_SIZE=20
PG_POOL_TIMEOUT=30

# ── GPU Provider Configuration ────────────────────────────────────────────────
# Optional but recommended: local GPU for compression (LETHE, ALETHEIA, ANAMNESIS)
# Supported: vLLM, Ollama, or any OpenAI-compatible inference server
# MNEMOS works without GPU but falls back to CPU compression (slower)
GPU_PROVIDER_HOST=http://localhost
GPU_PROVIDER_PORT=8000
GPU_PROVIDER_TIMEOUT=30.0
GPU_PROVIDER_MODEL=gemma4-e4b  # or your preferred model

# Ollama-specific (if using Ollama for embeddings)
OLLAMA_HOST=http://localhost
OLLAMA_PORT=11434
EMBEDDING_MODEL=nomic-embed-text

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# For GRAEAE multi-provider consensus engine
# Recommended: Together AI and Groq (free tier available)

# Together AI
TOGETHER_API_KEY=your_together_api_key_here

# Groq (free tier, high throughput)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic/Claude (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Authentication ────────────────────────────────────────────────────────────
# Bearer token for API authentication (generate with: openssl rand -hex 32)
MNEMOS_API_KEY=your_secure_api_key_here

# ── Redis Cache (Optional) ────────────────────────────────────────────────────
# For session caching and compression results
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60

# ── CORS Configuration ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://127.0.0.1:5002

# ── Request Size Limit ────────────────────────────────────────────────────────
MAX_BODY_BYTES=5242880  # 5 MB

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Enable compression tiers (LETHE, ALETHEIA, ANAMNESIS)
COMPRESSION_TIER_1_ENABLED=true   # LETHE (CPU, always available)
COMPRESSION_TIER_2_ENABLED=true   # ALETHEIA (GPU, if GPU_PROVIDER available)
COMPRESSION_TIER_3_ENABLED=false  # ANAMNESIS (experimental)

# ── DAG Versioning (Memory History) ───────────────────────────────────────────
# Enable git-like versioning for memories (branch, merge, revert)
DAG_VERSIONING_ENABLED=true

# ── Sessions (Stateful Chat) ──────────────────────────────────────────────────
# Enable multi-turn stateful conversations with memory injection
SESSIONS_ENABLED=true

# ── OpenAI-Compatible Gateway ─────────────────────────────────────────────────
# Enable /v1/chat/completions endpoint with auto memory injection
OPENAI_GATEWAY_ENABLED=true

# ── Distillation Worker ───────────────────────────────────────────────────────
# Background worker for async compression and fact extraction
DISTILLATION_WORKER_ENABLED=true
DISTILLATION_WORKER_CHECK_INTERVAL_SECONDS=10

# ── GRAEAE Provider Configuration ─────────────────────────────────────────────
# Multi-provider consensus engine for reasoning tasks
# Default providers: Together, Groq, OpenAI, Anthropic
GRAEAE_PROVIDERS=together,groq,openai,anthropic
GRAEAE_CONSENSUS_MODE=true
GRAEAE_CONSENSUS_QUORUM_SIZE=3
GRAEAE_CACHE_ENABLED=true
GRAEAE_CACHE_TTL_SECONDS=3600

# ── Development/Testing ───────────────────────────────────────────────────────
ENVIRONMENT=development  # or: production, staging
DEBUG=false
SQLALCHEMY_ECHO=false  # Set true to log all SQL queries
