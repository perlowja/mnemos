# PostgreSQL configuration
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=mnemos
PG_USER=mnemos_user
PG_PASSWORD=change_me

# API configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false
API_THREADED=true
API_VERSION=2.3.0

# GRAEAE configuration
GRAEAE_HOST=localhost
GRAEAE_PORT=5001
GRAEAE_URL=http://localhost:5001
GRAEAE_FALLBACK_ON_ERROR=true

# Embedding / inference endpoints
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_TIMEOUT=10

# Feature flags
ENABLE_TIER_SELECTION=true
ENABLE_GRAEAE=true
ENABLE_BACKGROUND_EMBEDDING=true
ENABLE_DISTILLATION=true
ENABLE_JSON_SHARD_SYNC=false

# Performance
MAX_MEMORIES=10000
MEMORY_TTL_DAYS=7
CACHE_TTL_MINUTES=60

# Provider keys should be stored in ~/.config/mnemos/api_keys.json
# or supplied via MNEMOS_KEYS_PATH
