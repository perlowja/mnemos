class MemoryItem(BaseModel):
    id: str
    content: str
    category: str
    created: str
    updated: Optional[str] = None
    metadata: Optional[Dict[str, Any]] = None
    quality_rating: Optional[int] = None

class MemoryListResponse(BaseModel):
    count: int
    memories: List[MemoryItem]

class MemorySearchRequest(BaseModel):
    query: str
    limit: int = 10
    category: Optional[str] = None

class MemoryCreateRequest(BaseModel):
    content: str
    category: str = "facts"
    metadata: Optional[Dict[str, Any]] = None
    source: Optional[str] = "openclaw"

async def _get_db():
    return await asyncpg.connect(user='mnemos_user', password='mnemos_password', database='mnemos', host='localhost')

def _row_to_memory(row):
    import json as _json
    raw_meta = row.get('metadata')
    if isinstance(raw_meta, str):
        try:
            raw_meta = _json.loads(raw_meta)
        except Exception:
            raw_meta = None
    elif not isinstance(raw_meta, dict):
        raw_meta = None
    return MemoryItem(
        id=row['id'],
        content=row['content'][:2000],
        category=row['category'],
        created=row['created'].isoformat() if row['created'] else '',
        updated=row['updated'].isoformat() if row.get('updated') else None,
        metadata=raw_meta if raw_meta else None,
        quality_rating=row.get('quality_rating'),
    )

@app.get("/memories", response_model=MemoryListResponse)
async def list_memories(category: Optional[str] = None, limit: int = 20, offset: int = 0):
    conn = await _get_db()
    try:
        if category:
            rows = await conn.fetch('SELECT id, content, category, created, updated, metadata, quality_rating FROM memories WHERE category=$1 ORDER BY created DESC LIMIT $2 OFFSET $3', category, limit, offset)
            total = await conn.fetchval('SELECT COUNT(*) FROM memories WHERE category=$1', category)
        else:
            rows = await conn.fetch('SELECT id, content, category, created, updated, metadata, quality_rating FROM memories ORDER BY created DESC LIMIT $1 OFFSET $2', limit, offset)
            total = await conn.fetchval('SELECT COUNT(*) FROM memories')
        return MemoryListResponse(count=total, memories=[_row_to_memory(r) for r in rows])
    finally:
        await conn.close()

@app.get("/memories/{memory_id}", response_model=MemoryItem)
async def get_memory(memory_id: str):
    conn = await _get_db()
    try:
        row = await conn.fetchrow('SELECT id, content, category, created, updated, metadata, quality_rating FROM memories WHERE id=$1', memory_id)
        if not row:
            raise HTTPException(status_code=404, detail="Memory not found")
        return _row_to_memory(row)
    finally:
        await conn.close()

@app.post("/memories/search", response_model=MemoryListResponse)
async def search_memories(request: MemorySearchRequest):
    conn = await _get_db()
    try:
        query_tsv = ' & '.join(request.query.split())
        if request.category:
            rows = await conn.fetch("SELECT id, content, category, created, updated, metadata, quality_rating, ts_rank(to_tsvector('english', content), to_tsquery('english', $1)) as rank FROM memories WHERE to_tsvector('english', content) @@ to_tsquery('english', $1) AND category=$3 ORDER BY rank DESC LIMIT $2", query_tsv, request.limit, request.category)
        else:
            rows = await conn.fetch("SELECT id, content, category, created, updated, metadata, quality_rating, ts_rank(to_tsvector('english', content), to_tsquery('english', $1)) as rank FROM memories WHERE to_tsvector('english', content) @@ to_tsquery('english', $1) ORDER BY rank DESC LIMIT $2", query_tsv, request.limit)
        return MemoryListResponse(count=len(rows), memories=[_row_to_memory(r) for r in rows])
    except Exception as e:
        logger.warning(f"FTS failed, falling back to ILIKE: {e}")
        like_q = f"%{request.query}%"
        if request.category:
            rows = await conn.fetch('SELECT id, content, category, created, updated, metadata, quality_rating FROM memories WHERE content ILIKE $1 AND category=$3 ORDER BY created DESC LIMIT $2', like_q, request.limit, request.category)
        else:
            rows = await conn.fetch('SELECT id, content, category, created, updated, metadata, quality_rating FROM memories WHERE content ILIKE $1 ORDER BY created DESC LIMIT $2', like_q, request.limit)
        return MemoryListResponse(count=len(rows), memories=[_row_to_memory(r) for r in rows])
    finally:
        await conn.close()

@app.post("/memories", response_model=MemoryItem)
async def create_memory(request: MemoryCreateRequest):
    import uuid, json
    mem_id = f"mem_{uuid.uuid4().hex[:12]}"
    conn = await _get_db()
    try:
        meta = json.dumps(request.metadata or {"source": request.source})
        await conn.execute("INSERT INTO memories (id, content, category, metadata, quality_rating) VALUES ($1, $2, $3, $4::jsonb, 75)", mem_id, request.content, request.category, meta)
        row = await conn.fetchrow('SELECT id, content, category, created, updated, metadata, quality_rating FROM memories WHERE id=$1', mem_id)
        return _row_to_memory(row)
    finally:
        await conn.close()




